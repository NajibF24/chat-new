import axios from 'axios';
import fs from 'fs/promises';
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

class SmartsheetService {
  constructor() {
    this.apiKey = process.env.SMARTSHEET_API_KEY;
    this.baseURL = 'https://api.smartsheet.com/2.0';
    this.dashboardId = process.env.SMARTSHEET_DASHBOARD_ID;
    this.tempDir = path.join(__dirname, '..', 'temp');
    
    this.axiosInstance = axios.create({
      baseURL: this.baseURL,
      headers: {
        'Authorization': `Bearer ${this.apiKey}`,
        'Content-Type': 'application/json'
      },
      timeout: 30000
    });
  }

  async ensureTempDir() {
    try {
      await fs.mkdir(this.tempDir, { recursive: true });
    } catch (error) {
      console.error('Error creating temp directory:', error);
    }
  }

  /**
   * Get dashboard details with all widgets
   */
  async getDashboard(dashboardId = null) {
    try {
      const id = dashboardId || this.dashboardId;
      console.log('📊 Fetching dashboard:', id);
      
      const response = await this.axiosInstance.get(`/sights/${id}`);
      return response.data;
    } catch (error) {
      console.error('❌ Error fetching dashboard:', error.message);
      throw new Error(`Failed to fetch dashboard: ${error.message}`);
    }
  }

  /**
   * Get dashboard summary with image info
   */
  async getDashboardSummary(dashboardId = null) {
    try {
      const dashboard = await this.getDashboard(dashboardId);
      
      const summary = {
        name: dashboard.name,
        description: dashboard.description || '',
        totalWidgets: dashboard.widgets?.length || 0,
        widgets: []
      };

      if (dashboard.widgets) {
        dashboard.widgets.forEach(widget => {
          const widgetInfo = {
            type: widget.type,
            title: widget.title || 'Untitled',
            id: widget.id
          };

          // Add specific info for image widgets
          if (widget.type === 'IMAGE') {
            widgetInfo.fileName = widget.contents?.fileName || 'No filename';
            widgetInfo.privateId = widget.contents?.privateId || null;
            widgetInfo.imageNote = 'Image widget detected (download may not be available via API)';
          }

          // Add info for other widget types
          if (widget.type === 'SHEETSUMMARY') {
            widgetInfo.sheetId = widget.contents?.sheetId;
            widgetInfo.viewId = widget.contents?.viewId;
          }

          if (widget.type === 'CHART') {
            widgetInfo.chartType = widget.contents?.chartType;
          }

          summary.widgets.push(widgetInfo);
        });
      }

      return summary;
    } catch (error) {
      console.error('❌ Error getting dashboard summary:', error.message);
      throw error;
    }
  }

  /**
   * Get all sheets from workspace
   */
  async getSheets() {
    try {
      console.log('📋 Fetching all sheets...');
      const response = await this.axiosInstance.get('/sheets', {
        params: {
          includeAll: true
        }
      });
      
      const sheets = response.data.data || [];
      console.log(`✅ Found ${sheets.length} sheet(s)`);
      return sheets;
    } catch (error) {
      console.error('❌ Error fetching sheets:', error.message);
      throw error;
    }
  }

  /**
   * Get detailed sheet data by ID
   */
  async getSheet(sheetId) {
    try {
      console.log('📄 Fetching sheet details:', sheetId);
      const response = await this.axiosInstance.get(`/sheets/${sheetId}`, {
        params: {
          include: 'attachments,discussions',
          level: 2
        }
      });
      return response.data;
    } catch (error) {
      console.error('❌ Error fetching sheet:', error.message);
      throw error;
    }
  }

  /**
   * Get projects (sheets with "project" keyword)
   */
  async getProjects() {
    try {
      const sheets = await this.getSheets();
      const projects = sheets.filter(sheet => 
        sheet.name.toLowerCase().includes('project') ||
        sheet.name.toLowerCase().includes('proyek') ||
        sheet.name.toLowerCase().includes('task') ||
        sheet.name.toLowerCase().includes('tracking')
      );
      
      console.log(`📊 Found ${projects.length} project sheet(s)`);
      return projects;
    } catch (error) {
      console.error('❌ Error fetching projects:', error.message);
      throw error;
    }
  }

  /**
   * Get project details with full data
   */
  async getProjectDetails(sheetId) {
    try {
      const sheet = await this.getSheet(sheetId);
      
      return {
        id: sheet.id,
        name: sheet.name,
        permalink: sheet.permalink,
        totalRows: sheet.totalRowCount || sheet.rows?.length || 0,
        totalColumns: sheet.columns?.length || 0,
        createdAt: sheet.createdAt,
        modifiedAt: sheet.modifiedAt,
        columns: sheet.columns?.map(col => ({
          id: col.id,
          title: col.title,
          type: col.type,
          primary: col.primary || false
        })) || [],
        rows: this.processRows(sheet.rows, sheet.columns),
        attachments: sheet.attachments?.length || 0,
        discussions: sheet.discussions?.length || 0
      };
    } catch (error) {
      console.error('❌ Error getting project details:', error.message);
      throw error;
    }
  }

  /**
   * Process rows to readable format
   */
  processRows(rows, columns) {
    if (!rows || !columns) return [];

    return rows.map(row => {
      const processedRow = {
        rowNumber: row.rowNumber,
        id: row.id,
        data: {}
      };

      row.cells.forEach((cell, index) => {
        const column = columns[index];
        if (column) {
          processedRow.data[column.title] = {
            value: cell.displayValue || cell.value || '',
            type: column.type
          };
        }
      });

      return processedRow;
    });
  }

  /**
   * Get comprehensive project report data
   */
  async getProjectReport(options = {}) {
    try {
      console.log('📊 Generating comprehensive project report...');
      
      const report = {
        generatedAt: new Date().toISOString(),
        dashboard: null,
        projects: []
      };

      // Get dashboard summary
      try {
        report.dashboard = await this.getDashboardSummary();
        console.log('✅ Dashboard summary retrieved');
      } catch (dashError) {
        console.log('⚠️ Could not fetch dashboard:', dashError.message);
      }

      // Get all projects
      const projects = await this.getProjects();
      const maxProjects = options.maxProjects || 5;
      const projectsToProcess = projects.slice(0, maxProjects);

      console.log(`📋 Processing ${projectsToProcess.length} project(s)...`);

      for (const project of projectsToProcess) {
        try {
          console.log(`   📄 Processing: ${project.name}...`);
          const details = await this.getProjectDetails(project.id);
          
          // Calculate statistics
          const stats = this.calculateProjectStats(details);
          
          report.projects.push({
            ...details,
            stats
          });
          
          console.log(`   ✅ ${project.name} processed`);
        } catch (projectError) {
          console.error(`   ❌ Error processing ${project.name}:`, projectError.message);
          report.projects.push({
            id: project.id,
            name: project.name,
            error: projectError.message
          });
        }
      }

      console.log('✅ Project report generated');
      return report;
    } catch (error) {
      console.error('❌ Error generating project report:', error.message);
      throw error;
    }
  }

  /**
   * Calculate project statistics
   */
  calculateProjectStats(project) {
    const stats = {
      totalTasks: project.totalRows,
      totalColumns: project.totalColumns,
      hasAttachments: project.attachments > 0,
      hasDiscussions: project.discussions > 0,
      completionRate: 0,
      tasksByStatus: {}
    };

    // Analyze rows for completion status
    if (project.rows && project.rows.length > 0) {
      const statusColumn = project.columns.find(col => 
        col.title.toLowerCase().includes('status') ||
        col.title.toLowerCase().includes('progress')
      );

      if (statusColumn) {
        project.rows.forEach(row => {
          const status = row.data[statusColumn.title]?.value || 'Unknown';
          stats.tasksByStatus[status] = (stats.tasksByStatus[status] || 0) + 1;
        });

        // Calculate completion rate
        const completedTasks = Object.keys(stats.tasksByStatus)
          .filter(status => 
            status.toLowerCase().includes('complete') ||
            status.toLowerCase().includes('done') ||
            status.toLowerCase().includes('finish')
          )
          .reduce((sum, status) => sum + stats.tasksByStatus[status], 0);
        
        stats.completionRate = project.totalRows > 0 
          ? Math.round((completedTasks / project.totalRows) * 100)
          : 0;
      }
    }

    return stats;
  }

  /**
   * Get image widget information (metadata only)
   */
  async getImageWidgetsList(dashboardId = null) {
    try {
      const dashboard = await this.getDashboard(dashboardId);
      
      const imageWidgets = dashboard.widgets
        ?.filter(w => w.type === 'IMAGE')
        .map(w => ({
          id: w.id,
          title: w.title || 'Untitled',
          fileName: w.contents?.fileName || 'No filename',
          privateId: w.contents?.privateId,
          note: 'Direct image download not supported by Smartsheet API'
        })) || [];

      return {
        totalImages: imageWidgets.length,
        images: imageWidgets,
        dashboardUrl: `https://app.smartsheet.com/dashboards/${dashboardId || this.dashboardId}`
      };
    } catch (error) {
      console.error('❌ Error getting image widgets:', error.message);
      throw error;
    }
  }

  /**
   * Format sheet data for AI
   */
  formatSheetForAI(sheet) {
    try {
      const columns = sheet.columns?.map(col => col.title).join(', ') || 'No columns';
      const rowCount = sheet.rows?.length || 0;
      
      let formatted = `📋 Sheet: ${sheet.name}\n`;
      formatted += `📊 Columns: ${columns}\n`;
      formatted += `📈 Total Rows: ${rowCount}\n`;
      formatted += `🔗 Link: ${sheet.permalink || 'N/A'}\n\n`;

      if (sheet.rows && sheet.rows.length > 0) {
        formatted += '📝 Data Preview (first 10 rows):\n';
        const previewRows = sheet.rows.slice(0, 10);
        
        previewRows.forEach((row, idx) => {
          formatted += `\nRow ${idx + 1}:\n`;
          row.cells.forEach((cell, cellIdx) => {
            const column = sheet.columns?.[cellIdx];
            if (column && (cell.displayValue || cell.value)) {
              formatted += `  • ${column.title}: ${cell.displayValue || cell.value}\n`;
            }
          });
        });

        if (sheet.rows.length > 10) {
          formatted += `\n... (${sheet.rows.length - 10} more rows)\n`;
        }
      }

      return formatted;
    } catch (error) {
      console.error('❌ Error formatting sheet:', error.message);
      return `Error formatting sheet: ${error.message}`;
    }
  }

  /**
   * Format project report for AI
   */
  formatReportForAI(report) {
    try {
      let formatted = `📊 SMARTSHEET PROJECT REPORT\n`;
      formatted += `⏰ Generated: ${new Date(report.generatedAt).toLocaleString('id-ID')}\n\n`;

      // Dashboard info
      if (report.dashboard) {
        formatted += `📱 Dashboard: ${report.dashboard.name}\n`;
        formatted += `📦 Total Widgets: ${report.dashboard.totalWidgets}\n\n`;
      }

      // Projects
      formatted += `📋 PROJECTS (${report.projects.length}):\n\n`;
      
      report.projects.forEach((project, idx) => {
        if (project.error) {
          formatted += `${idx + 1}. ❌ ${project.name}: ${project.error}\n\n`;
          return;
        }

        formatted += `${idx + 1}. 📊 ${project.name}\n`;
        formatted += `   🔢 Tasks: ${project.stats.totalTasks}\n`;
        formatted += `   📈 Completion: ${project.stats.completionRate}%\n`;
        
        if (Object.keys(project.stats.tasksByStatus).length > 0) {
          formatted += `   📋 Status Breakdown:\n`;
          Object.entries(project.stats.tasksByStatus).forEach(([status, count]) => {
            formatted += `      • ${status}: ${count}\n`;
          });
        }
        
        formatted += `   📅 Last Modified: ${new Date(project.modifiedAt).toLocaleString('id-ID')}\n`;
        formatted += `   🔗 Link: ${project.permalink}\n\n`;
      });

      return formatted;
    } catch (error) {
      console.error('❌ Error formatting report:', error.message);
      return `Error formatting report: ${error.message}`;
    }
  }

  /**
   * Clean up temp files
   */
  async cleanupTempFiles() {
    try {
      await this.ensureTempDir();
      const files = await fs.readdir(this.tempDir);
      const now = Date.now();
      const oneHour = 60 * 60 * 1000;

      for (const file of files) {
        const filepath = path.join(this.tempDir, file);
        const stats = await fs.stat(filepath);
        
        if (now - stats.mtimeMs > oneHour) {
          await fs.unlink(filepath);
          console.log('🗑️ Cleaned up:', file);
        }
      }
    } catch (error) {
      console.error('❌ Cleanup error:', error.message);
    }
  }
}

export default new SmartsheetService();
